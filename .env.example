# FORGE works with zero environment variables.
# Every value below is OPTIONAL. Set only what you actually use.
#
# See docs/configuration.md for the full reference.

# ── LLM (pick one or none — heuristic fallback always works) ────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:1.5b

# ── Optional integrations ─────────────────────────────────────────────────
GITHUB_TOKEN=
SLACK_SIGNING_SECRET=

# ── Safety toggles (defaults are conservative; only override knowingly) ──
DRY_RUN_MODE=true
REQUIRE_HUMAN_APPROVAL=true
