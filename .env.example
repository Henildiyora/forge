APP_NAME=devops-swarm
APP_ENV=development
LOG_LEVEL=INFO
LOG_JSON=true

ANTHROPIC_API_KEY=your_key_here
LLM_MODEL=claude-sonnet-4-20250514
LLM_MAX_TOKENS=8192

GITHUB_TOKEN=your_token_here
GITHUB_ORG=your_org_here

REDIS_URL=redis://localhost:6379/0
REDIS_STREAM_PREFIX=swarm
REDIS_STREAM_BLOCK_MS=1000
REDIS_CONSUMER_BATCH_SIZE=10
REDIS_STREAM_MAXLEN=10000

KUBECONFIG_PATH=~/.kube/config
K8S_NAMESPACE=devops-swarm

PROMETHEUS_URL=http://localhost:9090
LOKI_URL=http://localhost:3100

SLACK_WEBHOOK_URL=your_webhook_here
SLACK_APPROVAL_CHANNEL=#devops-approvals

VCLUSTER_BINARY_PATH=/usr/local/bin/vcluster
SANDBOX_MAX_AGE_MINUTES=30

DRY_RUN_MODE=true
REQUIRE_HUMAN_APPROVAL=true
